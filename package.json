{
    "name": "appium-boilerplate",
    "version": "5.3.1",
    "author": "Wim Selles <wim@wswebcreation.nl>",
    "license": "MIT",
    "description": "Boilerplate project to run WebdriverIO tests with Appium to test native applications on iOS and Android",
    "homepage": "https://github.com/webdriverio/appium-boilerplate#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/webdriverio/appium-boilerplate.git"
    },
    "bugs": {
        "url": "https://github.com/webdriverio/appium-boilerplate/issues"
    },
    "engines": {
        "node": "^16.13.0 || >=18.0.0"
    },
    "keywords": [
        "WebdriverIO",
        "WebDriver",
        "appium",
        "native app",
        "hybrid",
        "android",
        "ios"
    ],
    "type": "module",
    "scripts": {
        "postinstall": "node scripts/patch-unicorn-magic.mjs && node scripts/patch-webdriver.mjs",
        "android.app": "wdio run config/wdio.android.app.conf.ts",
        "android.browser": "wdio run config/wdio.android.browser.conf.ts",
        "android.hotel": "wdio run config/wdio.android.hotel.conf.ts",
        "rtk.hotel": "wdio run config/wdio.rtk.hotel.conf.ts",
        "rtk.ios.hotel": "wdio run config/wdio.rtk.ios.hotel.conf.ts",
        "rtk.android.hotel": "wdio run config/wdio.rtk.android.hotel.conf.ts",
        "browser": "wdio run config/wdio.browser.conf.ts",
        "ios.app": "wdio run config/wdio.ios.app.conf.ts",
        "ios.browser": "wdio run config/wdio.ios.browser.conf.ts",
        "lint": "eslint config tests",
        "appium:inspector": "npx start-appium-inspector",
        "allure:hotel": "npm run android.hotel -- --spec tests/specs/hotel.reserve.spec.ts --logLevel error && npx allure generate allure-results --clean -o allure-report-latest && npx allure open allure-report-latest",
        "notify:slack": "node scripts/notify-slack.mjs"
    },
    "devDependencies": {
        "@types/sharp": "^0.31.1",
        "@typescript-eslint/eslint-plugin": "^8.50.1",
        "@typescript-eslint/parser": "^8.50.1",
        "@wdio/allure-reporter": "^9.27.0",
        "@wdio/appium-service": "^9.27.1",
        "@wdio/cli": "^9.27.1",
        "@wdio/globals": "^9.27.1",
        "@wdio/local-runner": "^9.27.1",
        "@wdio/mocha-framework": "^9.27.1",
        "@wdio/spec-reporter": "^9.27.1",
        "allure-commandline": "^2.40.0",
        "appium": "^3.1.2",
        "appium-inspector-plugin": "^2026.5.1",
        "appium-uiautomator2-driver": "^7.4.0",
        "appium-xcuitest-driver": "^11.4.2",
        "eslint-plugin-wdio": "^9.16.2",
        "sharp": "^0.34.5",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    }
}
